<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Division 2 Retaliation Blueprint Tracker</title>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        :root {
            --orange: #ff6600;
            --bg-body: #0d0d0d;
            --bg-card: #1a1a1a;
            --border: #2a2a2a;
            --text: #e0e0e0;
            --input-bg: #141414;
        }
        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            background-color: var(--bg-body);
            color: var(--text);
            padding: 15px;
        }
        .container { max-width: 900px; margin: 0 auto; }
        
        header { 
            text-align: center; 
            padding: 30px 0; 
            border-bottom: 2px solid var(--orange); 
            margin-bottom: 25px; 
        }
        h1 { 
            color: var(--orange); 
            text-transform: uppercase; 
            letter-spacing: 2px; 
            font-size: 1.6rem; 
            margin: 0;
        }
        
        .sticky-box {
            position: sticky;
            top: 10px;
            z-index: 100;
            background: var(--bg-card);
            padding: 20px;
            border-radius: 8px;
            border: 1px solid var(--border);
            margin-bottom: 30px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.8);
        }
        .prog-info { 
            display: flex; 
            justify-content: space-between; 
            margin-bottom: 12px; 
            font-weight: bold; 
            font-size: 0.85rem; 
            text-transform: uppercase; 
            color: #888;
        }
        #stats { color: var(--orange); }
        
        .bar-outer { background: #000; height: 12px; border-radius: 6px; overflow: hidden; border: 1px solid #333; margin-bottom: 20px; }
        #bar-inner { background: linear-gradient(90deg, #cc5200, var(--orange)); height: 100%; width: 0%; transition: width 0.5s ease; }
        
        input#search {
            width: 100%;
            padding: 14px 18px;
            background: var(--input-bg);
            border: 1px solid var(--border);
            color: #fff;
            border-radius: 6px;
            font-size: 15px;
            transition: all 0.3s ease;
        }
        input#search:focus { 
            border-color: #444; 
            background: #1a1a1a;
            outline: none; 
            box-shadow: 0 0 10px rgba(255,102,0,0.1);
        }
        
        .grid { display: block; }
        .f-card { 
            background: var(--bg-card); 
            border-top: 3px solid var(--orange); 
            padding: 20px; 
            border-radius: 4px; 
            margin-bottom: 15px;
            border-left: 1px solid var(--border);
            border-right: 1px solid var(--border);
            border-bottom: 1px solid var(--border);
        }
        
        .f-header {
            cursor: pointer;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .f-title { 
            color: var(--orange); 
            text-transform: uppercase; 
            font-size: 1.2rem; 
            font-weight: 800; 
            margin: 0;
            letter-spacing: 1px;
        }

        .arrow {
            color: #555;
            font-size: 0.7rem;
            transition: transform 0.3s ease;
        }

        .f-card.open .arrow { transform: rotate(180deg); color: var(--orange); }
        .f-content { display: none; padding-top: 15px; }
        .f-card.open .f-content { display: block; }
        
        .g-label { font-size: 0.7rem; color: var(--orange); background: rgba(255,102,0,0.08); padding: 3px 10px; border-radius: 3px; text-transform: uppercase; margin: 15px 0 10px; font-weight: bold; width: fit-content; border: 1px solid rgba(255,102,0,0.2); }
        .list { list-style: none; }
        .row { display: flex; align-items: center; padding: 10px 0; border-bottom: 1px solid #222; }
        .row:last-child { border-bottom: none; }
        
        input[type="checkbox"] { width: 18px; height: 18px; margin-right: 15px; accent-color: var(--orange); cursor: pointer; }
        label { flex: 1; cursor: pointer; font-size: 0.95rem; color: #bbb; }
        input:checked + label { color: #444; text-decoration: line-through; }
        .hidden { display: none !important; }

        /* Footer Credit Style */
        footer {
            text-align: center;
            padding: 40px 0 20px;
            color: #555;
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 1px;
        }
        .credit-name {
            color: var(--orange);
            font-weight: bold;
        }
    </style>
</head>
<body>

<div class="container">
    <header>
        <h1>Division 2 Retaliation Blueprint Tracker</h1>
    </header>

    <div class="sticky-box">
        <div class="prog-info">
            <span>Blueprint Completion</span>
            <span id="stats">0 / 55 (0%)</span>
        </div>
        <div class="bar-outer"><div id="bar-inner"></div></div>
        <input type="text" id="search" placeholder="Filter by blueprint or faction..." onkeyup="doSearch()">
    </div>

    <div id="grid" class="grid"></div>

    <footer>
        Made By : <span class="credit-name">Skidrush</span>
    </footer>
</div>

<script>
    const data = [
        { name: "Rikers", groups: [{ t: "Kill Squad", items: ["Bullet King", "Ninjabike Backpack", "Bloody Knuckles"] }] },
        { name: "True Sons", groups: [
            { t: "Kill Squad", items: ["Lady Death", "Doctor Home", "Catharsis", "St. Elmo's Engine", "Dread Edict", "Busy Little Bee", "Shocker Punch", "Pakhan"] },
            { t: "Completion", items: ["Blue Screen", "BTSU Datagloves", "Tardigrade", "Exodus Gloves"] }
        ]},
        { name: "Outcasts", groups: [
            { t: "Kill Squad", items: ["Backfire", "Pestilence", "Sweet Dreams", "Collector", "Memento", "Acosta's Go-Bag", "Acosta's Kneepads", "Shroud"] },
            { t: "Completion", items: ["Vile", "Rugged Gauntlets", "Waveform", "Nimble Holster"] }
        ]},
        { name: "Hyenas", groups: [
            { t: "Kill Squad", items: ["Merciless", "Coyote's Mask", "Sawyer's Kneepads", "Overlord", "Strega", "Centurion's Scabbard", "Sacrum Imperium", "Oxpecker"] },
            { t: "Completion", items: ["Chameleon", "Mosquito", "Mantis", "Scorpio", "Overdogs"] }
        ]},
        { name: "Cleaners", groups: [{ t: "Kill Squad", items: ["Iron Lung", "Ninjabike Kneepads", "Imperial Dynasty"] }] },
        { name: "Black Tusk", groups: [
            { t: "Kill Squad", items: ["Capacitor", "Sheriff", "Vindicator", "Tempest", "Birdie's Quick Fix Pack", "Provocator", "Blacklister", "Tinkerer"] },
            { t: "Completion Bonus", items: ["Eagle Bearer", "Big Horn", "Ouroboros", "Diamondback", "Ravenous"] }
        ]}
    ];

    const grid = document.getElementById('grid');
    data.forEach(f => {
        let h = `
            <div class="f-card" data-f="${f.name.toLowerCase()}">
                <div class="f-header" onclick="toggleFaction(this)">
                    <h2 class="f-title">${f.name}</h2>
                    <span class="arrow">▼</span>
                </div>
                <div class="f-content">`;
        f.groups.forEach(g => {
            h += `<div class="g-label">${g.t}</div><ul class="list">`;
            g.items.forEach(i => {
                const id = i.replace(/\s+/g, '-').replace(/'/g, '').toLowerCase();
                h += `<li class="row" data-i="${i.toLowerCase()}"><input type="checkbox" id="${id}" class="cb" onchange="upd()"><label for="${id}">${i}</label></li>`;
            });
            h += `</ul>`;
        });
        h += `</div></div>`;
        grid.innerHTML += h;
    });

    function toggleFaction(element) {
        element.parentElement.classList.toggle('open');
    }

    function upd() {
        const all = document.querySelectorAll('.cb'), ch = document.querySelectorAll('.cb:checked');
        const p = Math.round((ch.length / all.length) * 100);
        document.getElementById('bar-inner').style.width = p + '%';
        document.getElementById('stats').innerText = `${ch.length} / ${all.length} (${p}%)`;
        localStorage.setItem('div2_blueprint_tracker', JSON.stringify(Array.from(all).map(c => ({id: c.id, v: c.checked}))));
    }

    function doSearch() {
        const q = document.getElementById('search').value.toLowerCase();
        document.querySelectorAll('.f-card').forEach(c => {
            let has = false;
            c.querySelectorAll('.row').forEach(r => {
                const match = r.getAttribute('data-i').includes(q) || c.getAttribute('data-f').includes(q);
                r.classList.toggle('hidden', !match);
                if(match) has = true;
            });
            c.classList.toggle('hidden', !has);
            if (q.length > 0 && has) {
                c.classList.add('open');
            } else if (q.length === 0) {
                c.classList.remove('open');
            }
        });
    }

    window.onload = () => {
        const s = JSON.parse(localStorage.getItem('div2_blueprint_tracker'));
        if(s) s.forEach(x => { const e = document.getElementById(x.id); if(e) e.checked = x.v; });
        upd();
    };
</script>
</body>
</html>
